{
  "manifest_version": 3,
  "name": "FocusFlow",
  "version": "3.0",
  "description": "Block distractions with timed locks, tasks/points, schedules, and analytics.",
  "permissions": ["declarativeNetRequest", "storage", "tabs", "webNavigation", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "FocusFlow" },
  "web_accessible_resources": [{
    "resources": ["blocked.html", "blocked.js", "dashboard.html", "dashboard.js"],
    "matches": ["<all_urls>"]
  }],
  "icons": { "16": "icons/icon_16.png", "48": "icons/icon_48.png", "128": "icons/icon_128.png" }
}
